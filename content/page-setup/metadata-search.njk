permalink: /metadata/search/
---

<section class="search">
  <h2>Metadata Search</h2>
  <p class="search-help">Searches the unified index built from <a href="/allsites.json">/allsites.json</a>.</p>
  <div id="metadata-search"></div>
  <p id="metadata-search-status" class="search-help" hidden>Search index not found yet. Run <code>npm run build</code> to generate Pagefind.</p>
</section>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css">
<script src="/pagefind/pagefind-ui.js"></script>
<script>
  window.addEventListener("DOMContentLoaded", () => {
    const status = document.getElementById("metadata-search-status");
    if (typeof PagefindUI === "undefined") {
      if (status) status.hidden = false;
      return;
    }

    new PagefindUI({
      element: "#metadata-search",
      showImages: false,
      processResult: (result) => {
        const meta = result?.meta || {};
        if (meta.source_url) {
          result.url = meta.source_url;
        }
        if (meta.title) {
          result.title = meta.site ? `${meta.title} | ${meta.site}` : meta.title;
        }
        if (meta.description) {
          result.excerpt = meta.description;
        }
        return result;
      },
    });
  });
</script>
