<section class="search">
  <h2>Semantic Metadata Search</h2>
  <p class="search-help">Searches across Whitestone Foundation publications using semantic similarity.</p>
  <form id="metasearch-form" class="metasearch-form" role="search">
    <label class="visually-hidden" for="metasearch-input">Search metadata</label>
    <input type="search" id="metasearch-input" placeholder="Search across articles, authors, journals, and sites" autocomplete="off">
    <button type="submit">Search</button>
  </form>
  <div id="metasearch-progress-wrap" class="metasearch-progress-wrap" hidden>
    <progress id="metasearch-progress" max="100" value="0"></progress>
    <div id="metasearch-progress-label" class="metasearch-progress-label">Preparing search...</div>
  </div>
  <div id="metasearch-status" class="search-help" aria-live="polite"></div>
  <div id="metasearch-results" class="metasearch-results" role="region" aria-label="Search results" aria-live="polite"></div>
</section>
<script src="/js/metasearch-ui.js" defer></script>
